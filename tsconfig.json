{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "next/server": ["node_modules/vinext/dist/shims/server.d.ts"],
      "next/navigation": ["node_modules/vinext/dist/shims/navigation.d.ts"],
      "next/link": ["node_modules/vinext/dist/shims/link.d.ts"],
      "next/image": ["node_modules/vinext/dist/shims/image.d.ts"]
    },
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*", "env.d.ts"]
}
