{
  "name": "rush",
  "main": "src/worker.ts",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "rush_db"
    }
  ],
  "r2_buckets": [
    {
      "binding": "STORAGE"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "SESSIONS"
    }
  ],
  "vars": {
    "JWT_SECRET": "change_me_in_production"
  }
}
